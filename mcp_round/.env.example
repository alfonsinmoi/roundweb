# MCP Round — variables de entorno
# Copia a .env y rellena

# Odoo
MCP_ODOO_URL=http://localhost:8069
MCP_ODOO_DB=round_facturacion
MCP_ODOO_USER=adminround
MCP_ODOO_PWD=                            # password real adminround

# Webhook auth (compartidos con NoofitPro)
MCP_WEBHOOK_TOKEN=                       # generar con: openssl rand -hex 24
MCP_WEBHOOK_SECRET=                      # generar con: openssl rand -hex 32

# Empresa Odoo por defecto (id=1 = Best Training)
MCP_DEFAULT_COMPANY_ID=1

# Modo desarrollo (relaja HMAC para tests locales). NO usar en producción.
MCP_DEV_MODE=0
