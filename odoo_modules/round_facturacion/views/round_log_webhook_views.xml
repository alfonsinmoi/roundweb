<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_round_log_webhook_tree" model="ir.ui.view">
        <field name="name">round.log.webhook.tree</field>
        <field name="model">round.log.webhook</field>
        <field name="arch" type="xml">
            <tree string="Logs de webhooks"
                  decoration-success="estado=='procesado'"
                  decoration-warning="estado=='pendiente'"
                  decoration-danger="estado=='error'">
                <field name="create_date"/>
                <field name="direccion"/>
                <field name="evento"/>
                <field name="partner_id"/>
                <field name="estado" widget="badge"/>
                <field name="intentos"/>
                <field name="webhook_id"/>
            </tree>
        </field>
    </record>

    <record id="view_round_log_webhook_form" model="ir.ui.view">
        <field name="name">round.log.webhook.form</field>
        <field name="model">round.log.webhook</field>
        <field name="arch" type="xml">
            <form string="Log webhook">
                <header>
                    <button name="action_reintentar" string="Reintentar" type="object"
                            class="btn-warning" invisible="estado != 'error'"/>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="pendiente,procesado,error"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="direccion"/>
                            <field name="evento"/>
                            <field name="webhook_id"/>
                            <field name="intentos"/>
                            <field name="procesado_at"/>
                        </group>
                        <group>
                            <field name="partner_id"/>
                            <field name="subscription_id"/>
                            <field name="invoice_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload">
                            <field name="payload" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                        <page string="Respuesta">
                            <field name="response" widget="ace" options="{'mode': 'json'}"/>
                        </page>
                        <page string="Error" invisible="not error_msg">
                            <field name="error_msg" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_round_log_webhook_search" model="ir.ui.view">
        <field name="name">round.log.webhook.search</field>
        <field name="model">round.log.webhook</field>
        <field name="arch" type="xml">
            <search>
                <field name="evento"/>
                <field name="webhook_id"/>
                <field name="partner_id"/>
                <separator/>
                <filter name="entrada" string="Entrada (NoofitPro→Odoo)" domain="[('direccion','=','entrada')]"/>
                <filter name="salida" string="Salida (Odoo→NoofitPro)" domain="[('direccion','=','salida')]"/>
                <separator/>
                <filter name="error" string="Errores" domain="[('estado','=','error')]"/>
                <filter name="pendiente" string="Pendientes" domain="[('estado','=','pendiente')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_evento"   string="Evento"   context="{'group_by':'evento'}"/>
                    <filter name="group_estado"   string="Estado"   context="{'group_by':'estado'}"/>
                    <filter name="group_direccion" string="Dirección" context="{'group_by':'direccion'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_round_log_webhook" model="ir.actions.act_window">
        <field name="name">Logs webhooks</field>
        <field name="res_model">round.log.webhook</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_pendiente': 1}</field>
    </record>

</odoo>
