<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_round_modificacion_recibo_tree" model="ir.ui.view">
        <field name="name">round.modificacion.recibo.tree</field>
        <field name="model">round.modificacion.recibo</field>
        <field name="arch" type="xml">
            <tree string="Modificaciones de recibo"
                  decoration-success="estado=='aplicada'"
                  decoration-muted="estado=='cancelada'">
                <field name="partner_id"/>
                <field name="subscription_id"/>
                <field name="fecha_desde"/>
                <field name="fecha_hasta"/>
                <field name="tipo"/>
                <field name="valor" widget="monetary"/>
                <field name="razon"/>
                <field name="estado" widget="badge"/>
                <field name="currency_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_round_modificacion_recibo_form" model="ir.ui.view">
        <field name="name">round.modificacion.recibo.form</field>
        <field name="model">round.modificacion.recibo</field>
        <field name="arch" type="xml">
            <form string="Modificación recibo">
                <header>
                    <button name="action_cancelar" string="Cancelar" type="object"
                            invisible="estado != 'activa'"
                            confirm="¿Cancelar esta modificación? Si ya se aplicó a algún recibo, no se revertirá."/>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="activa,aplicada,cancelada"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="subscription_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="tipo"/>
                            <field name="valor"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="fecha_desde"/>
                            <field name="fecha_hasta"/>
                            <field name="razon"/>
                            <field name="autorizado_por"/>
                            <field name="id_noofit_modificacion"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_round_modificacion_recibo" model="ir.actions.act_window">
        <field name="name">Modificaciones de recibo</field>
        <field name="res_model">round.modificacion.recibo</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
