# Round Configuración API — variables de entorno
CONFIG_DB_HOST=localhost
CONFIG_DB_PORT=5432
CONFIG_DB_NAME=round_config
CONFIG_DB_USER=odoo
CONFIG_DB_PWD=

# Token compartido (frontend Round usa este mismo)
